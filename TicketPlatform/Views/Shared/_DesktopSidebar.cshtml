@model Tuple<string, string>

<aside class="d-none d-md-flex flex-column bg-white border-end vh-100 position-fixed top-0 start-0 p-3"
       style="width: 280px;">

    <div class="d-flex align-items-center gap-2 mb-4">
        <div class="bg-primary text-white rounded-3 d-flex align-items-center justify-content-center fw-bold"
             style="width: 36px; height: 36px;">
            T
        </div>
        <div class="fw-bold">Ticket App</div>
    </div>

    <button class="btn btn-primary w-100 mb-4"
            data-bs-toggle="modal"
            data-bs-target="#createTicketModal"
            id="desktopQuickRequestButton">
        + Quick Request
    </button>

    <div class="nav nav-pills flex-column gap-1">
		<a class="nav-link @((ViewContext.RouteData.Values["controller"].ToString() == "Home" && ViewContext.RouteData.Values["action"].ToString() == "Index") ? "active" : "text-dark")" href="@Url.Action("Index", "Home")">Home</a>
		<a class="nav-link @((ViewContext.RouteData.Values["controller"].ToString() == "Home" && ViewContext.RouteData.Values["action"].ToString() == "MyTickets") ? "active" : "text-dark")" href="@Url.Action("MyTickets", "Home")">My Tickets</a>
		<a class="nav-link @((ViewContext.RouteData.Values["controller"].ToString() == "Home" && ViewContext.RouteData.Values["action"].ToString() == "DraftTickets") ? "active" : "text-dark")" href="@Url.Action("DraftTickets", "Home")">Draft Tickets</a>
		<a class="nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Profile" ? "active" : "text-dark")" href="@Url.Action("Index", "Profile")">My Profile</a>
    </div>

	<div class="mt-auto pt-3 border-top">
		<div class="d-flex align-items-center gap-2">
			<a href="@Url.Action("Index", "Profile")" class="text-decoration-none text-dark d-flex align-items-center gap-2">
				<div class="rounded-circle bg-secondary-subtle d-flex align-items-center justify-content-center fw-bold"
					 style="width: 38px; height: 38px;">
					@Model.Item1.Substring(0, 1).ToUpper()
				</div>

				<div class="small">
					<div class="fw-bold">@Model.Item1</div>
					<div class="text-muted">@Model.Item2</div>
				</div>
			</a>
		</div>

        <a href="/Auth/Logout" class="btn btn-link text-danger px-0 mt-3 fw-bold text-decoration-none">
            Sign Out
        </a>
    </div>
</aside>
