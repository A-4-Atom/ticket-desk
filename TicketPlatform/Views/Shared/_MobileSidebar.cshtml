@model Tuple<string, string>

<div class="offcanvas offcanvas-start"
     tabindex="-1"
     id="mobileSidebar"
     style="width: min(85vw, 320px);">

    <div class="offcanvas-header">
        <h5 class="offcanvas-title fw-bold">TicketMaster</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>

    <div class="offcanvas-body p-3">

		<button class="btn btn-primary w-100 mb-3"
				data-bs-toggle="modal"
				data-bs-target="#createTicketModal"
				data-bs-dismiss="offcanvas"
				id="mobileQuickRequestButton">
			+ Quick Request
		</button>

		<div class="nav nav-pills flex-column gap-1">
			<a class="nav-link" href="@Url.Action("Index", "Home")">Home</a>
			<a class="nav-link" href="@Url.Action("MyTickets", "Home")">My Tickets</a>
			<a class="nav-link" href="@Url.Action("DraftTickets", "Home")">Draft Tickets</a>
			<a class="nav-link" href="@Url.Action("Index", "Profile")">My Profile</a>
		</div>

        <div class="mt-auto pt-3 border-top">
			<div class="d-flex align-items-center gap-2">
				<a href="@Url.Action("Index", "Profile")" class="text-decoration-none text-dark d-flex align-items-center gap-2">
					<div class="rounded-circle bg-secondary-subtle d-flex align-items-center justify-content-center fw-bold"
						 style="width: 38px; height: 38px;">
						@Model.Item1.Substring(0, 1).ToUpper()
					</div>

					<div class="small">
						<div class="fw-bold">@Model.Item1</div>
						<div class="text-muted">@Model.Item2</div>
					</div>
				</a>
			</div>

            <a href="/Auth/Logout" class="btn btn-link text-danger px-0 mt-3 fw-bold text-decoration-none">
                Sign Out
            </a>
        </div>
    </div>
</div>
