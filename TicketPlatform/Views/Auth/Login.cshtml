@{
    ViewBag.Title = "Login";
    Layout = null;   // keep it blank (no navbar)
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login</title>

    @Styles.Render("~/Content/css")
</head>

<body class="bg-light">

    <div class="container min-vh-100 d-flex justify-content-center align-items-center">
        <div class="card shadow-sm border-0 rounded-4" style="max-width: 420px; width: 100%;">
            <div class="card-body p-4 p-md-5">

                <h2 class="fw-bold text-center mb-2">Welcome Back</h2>
                <p class="text-muted text-center mb-4">
                    Enter your details to access your tickets
                </p>

                <form method="post">

                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="email">Email Address</label>
                        <input id="email" type="email" class="form-control form-control-lg w-100"
                               placeholder="name@example.com" name="email" autocomplete="on" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="password">Password</label>
                        <input id="password" type="password" class="form-control form-control-lg"
                               placeholder="*******" name="password" />
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 mt-2">
                        Sign In
                    </button>
                </form>

                <div class="text-center mt-4">
                    <a href="/Auth/Signup" class="text-decoration-none fw-semibold">
                        Don't have an account? Sign Up
                    </a>
                </div>

            </div>
        </div>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
</body>
</html>
