@{
    ViewBag.Title = "Dashboard";

    // If user is not logged in
    if (Session["UserId"] == null)
    {
        Response.Redirect("/Auth/Login");
    }
}

<div class="container mt-5">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h1 class="display-5 fw-bold mb-2">
                        Welcome, <span>@(Session["UserName"] ?? "User")</span>! 👋
                    </h1>

                    <p class="text-muted mb-4">
                        Employee Code:
                        <span class="badge bg-primary">
                            @(Session["EmployeeCode"] ?? "N/A")
                        </span>
                    </p>

                    <p class="lead">You're successfully logged into the Ticket Platform.</p>

                    <div class="mt-4">
                        <a href="/Auth/Logout" class="btn btn-danger">Logout</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4" id="userInfo">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title">Your Role</h5>
                    <p class="card-text">
                        <span class="badge bg-success fs-6">
                            @(Session["Role"] ?? "N/A")
                        </span>
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title">User ID</h5>
                    <p class="card-text">
                        <code class="fs-6">@(Session["UserId"] ?? "")</code>
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title">Role Prefix</h5>
                    <p class="card-text">
                        <span class="badge bg-info fs-6">
                            @(Session["RolePrefix"] ?? "N/A")
                        </span>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
