@{
	ViewBag.Title = "Service Catalog";
	Layout = "~/Views/Shared/_Layout.cshtml";

	if (Session["UserId"] == null)
	{
		Response.Redirect("/Auth/Login");
	}

	var role = (Session["Role"] ?? "User").ToString();
	var isAdmin = role.Equals("Admin", StringComparison.OrdinalIgnoreCase);
}

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-between mb-4">
	<div>
		<h1 class="h3 fw-bold mb-1">How can we help you today?</h1>
		<p class="text-muted mb-0">Select a category below to submit a new request. Our team will get back to you shortly.</p>
	</div>
</div>

<div class="mb-4">
	<h2 class="h6 text-uppercase text-muted mb-2">Support Services <span class="text-secondary">3 options</span></h2>
	<div class="row g-3 g-md-4">
		<div class="col-12 col-md-4">
			@Html.Partial("_TicketTypeCard", new TicketPlatform.Models.TicketTypeViewModel
			{
				Key = "it-support",
				Title = "IT Support",
				Subtitle = "Hardware, Software, Access",
				Category = "IT Support"
			})
		</div>
		<div class="col-12 col-md-4">
			@Html.Partial("_TicketTypeCard", new TicketPlatform.Models.TicketTypeViewModel
			{
				Key = "hr-support",
				Title = "HR Support",
				Subtitle = "Benefits, Payroll, Policy",
				Category = "HR Support",
				RequiresConfidentiality = true
			})
		</div>
		<div class="col-12 col-md-4">
			@Html.Partial("_TicketTypeCard", new TicketPlatform.Models.TicketTypeViewModel
			{
				Key = "general-service",
				Title = "General Service",
				Subtitle = "Facilities, Maintenance",
				Category = "General Service"
			})
		</div>
	</div>
</div>

@if (isAdmin)
{
	<div class="mt-4">
		<h2 class="h6 text-uppercase text-muted mb-2">Operational Requests <span class="text-secondary">3 options</span></h2>
		<div class="row g-3 g-md-4">
			<div class="col-12 col-md-4">
				@Html.Partial("_TicketTypeCard", new TicketPlatform.Models.TicketTypeViewModel
				{
					Key = "new-employee",
					Title = "New Employee",
					Subtitle = "Onboarding, Access Setup",
					Category = "New Employee"
				})
			</div>
			<div class="col-12 col-md-4">
				@Html.Partial("_TicketTypeCard", new TicketPlatform.Models.TicketTypeViewModel
				{
					Key = "employee-separation",
					Title = "Employee Separation",
					Subtitle = "Offboarding, Clearance",
					Category = "Employee Separation"
				})
			</div>
			<div class="col-12 col-md-4">
				@Html.Partial("_TicketTypeCard", new TicketPlatform.Models.TicketTypeViewModel
				{
					Key = "asset-order",
					Title = "Asset Order",
					Subtitle = "Procurement, Inventory",
					Category = "Asset Order"
				})
			</div>
		</div>
	</div>
}

@Scripts.Render("~/bundles/jquery")
@Scripts.Render("~/bundles/bootstrap")
