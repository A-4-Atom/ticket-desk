@{
	var actionName = ViewBag.PaginationAction as string ?? "MyTickets";
}
<div class="d-flex align-items-center justify-content-between">
	<div class="text-muted small">
		Page @ViewBag.Page
	</div>

	<div class="d-flex gap-2">
		<a class="btn btn-outline-secondary btn-sm @(ViewBag.HasPrevPage ? "" : "disabled")"
		   href="@Url.Action(actionName, "Home", new { page = ViewBag.Page - 1 })">
			<
		</a>

		<a class="btn btn-outline-secondary btn-sm @(ViewBag.HasNextPage ? "" : "disabled")"
		   href="@Url.Action(actionName, "Home", new { page = ViewBag.Page + 1 })">
			>
		</a>
	</div>
</div>
