@model List<TicketPlatform.Models.Ticket>
@{
    var showSubmitAction = ViewBag.ShowSubmitAction == true;
    var role = (Session["Role"] ?? "User").ToString();
    var enableBulkClose = !showSubmitAction && string.Equals(role, "Admin", StringComparison.OrdinalIgnoreCase);
}

<div class="table-responsive">
    <table class="table align-middle mb-0">
        <thead class="text-uppercase small text-muted">
            <tr>
                @if (enableBulkClose)
                {
                    <th style="width: 40px;" class="text-center">
                        <input type="checkbox" id="selectAllTickets" class="form-check-input" />
                    </th>
                }
                <th class="text-nowrap">Ref ID</th>
                <th style="min-width: 220px;">Ticket Details</th>
                <th class="text-nowrap d-none d-md-table-cell">Category</th>
                <th class="text-nowrap d-none d-md-table-cell">Status</th>
                <th class="text-nowrap d-none d-md-table-cell">Created</th>
                @if (showSubmitAction)
                {
                    <th class="text-nowrap d-none d-md-table-cell">Actions</th>
                }
            </tr>
        </thead>

        <tbody id="ticketsBody">
        @if (ViewBag.TicketsLoadError == true)
        {
            <tr>
                <td colspan="@(5 + (showSubmitAction ? 1 : 0) + (enableBulkClose ? 1 : 0))" class="text-center text-danger py-4">
                    Tickets could not be loaded. Please try again later.
                </td>
            </tr>
        }
        else if (Model != null && Model.Count > 0)
        {
            foreach (var t in Model)
            {
                <tr data-ticket-id="@t.id">
                    @if (enableBulkClose && !t.isDraft)
                    {
                        <td class="text-center align-middle">
                            <input type="checkbox" class="form-check-input js-ticket-select" data-ticket-id="@t.id" />
                        </td>
                    }
                    <td class="text-nowrap fw-bold">@(!string.IsNullOrEmpty(t.confirmationNumber) ? t.confirmationNumber : "Draft")</td>

                    <td>
                        <div class="fw-semibold">@t.title</div>

                        @if (t.attachments != null && t.attachments.Count > 0)
                        {
                            <div class="small mt-1">
                                <span class="text-muted me-1">Attachments:</span>
                                @for (int i = 0; i < t.attachments.Count; i++)
                                {
                                    var a = t.attachments[i];
                                    <a href="@a.fileUrl" target="_blank">
                                        @a.fileName
                                    </a>

                                    if (i < t.attachments.Count - 1)
                                    {
                                        @:<span>, </span>
                                    }
                                }
                            </div>
                        }

                        <div class="text-muted small d-md-none mt-1">
                            <span class="me-2">@t.category</span>
                            <span class="me-2">
                                @DateTime.Parse(t.createdAt).ToString("yyyy-MM-dd")
                            </span>
                            <span>
                                <span class="badge bg-secondary">@t.status</span>
                            </span>
                        </div>

					@if (showSubmitAction)
					{
						<div class="mt-2 d-md-none">
							@using (Html.BeginForm("SubmitDraftTicket", "Home", new { ticketId = t.id }, FormMethod.Post, new { @class = "d-inline" }))
							{
								@Html.AntiForgeryToken()
								<button type="submit" class="btn btn-sm btn-success">
									Submit
								</button>
							}
						</div>
					}
                    </td>

                    <td class="text-nowrap d-none d-md-table-cell">@t.category</td>

                    <td class="text-nowrap d-none d-md-table-cell">
                        <span class="badge bg-secondary">@t.status</span>
                    </td>

                    <td class="text-nowrap d-none d-md-table-cell">
                        @DateTime.Parse(t.createdAt).ToString("yyyy-MM-dd")
                    </td>

                    @if (showSubmitAction)
                    {
                        <td class="text-nowrap d-none d-md-table-cell">
                            @using (Html.BeginForm("SubmitDraftTicket", "Home", new { ticketId = t.id }, FormMethod.Post, new { @class = "d-inline" }))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-success">
                                    Submit
                                </button>
                            }
                        </td>
                    }
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="@(5 + (showSubmitAction ? 1 : 0) + (enableBulkClose ? 1 : 0))" class="text-center text-muted py-4">
                    No tickets found.
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

@if (enableBulkClose)
{
    <div id="bulkCloseBar" class="card shadow-sm border-0 fixed-bottom m-3 d-none">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <span id="bulkCloseCount" class="fw-semibold">0</span> tickets selected.
            </div>
            <div>
                <button type="button" id="bulkCloseButton" class="btn btn-danger btn-sm">
                    Close selected
                </button>
            </div>
        </div>
    </div>

    <script type="text/javascript">
        (function () {
            function updateBulkCloseBar() {
                var all = document.querySelectorAll(".js-ticket-select");
                var checked = document.querySelectorAll(".js-ticket-select:checked");
                var count = checked.length;

                var countSpan = document.getElementById("bulkCloseCount");
                if (countSpan) {
                    countSpan.textContent = count.toString();
                }

                var bar = document.getElementById("bulkCloseBar");
                if (bar) {
                    if (count > 0) {
                        bar.classList.remove("d-none");
                    } else {
                        bar.classList.add("d-none");
                    }
                }

                var selectAll = document.getElementById("selectAllTickets");
                if (selectAll) {
                    if (all.length && count === all.length) {
                        selectAll.checked = true;
                    } else {
                        selectAll.checked = false;
                    }
                }
            }

            document.addEventListener("change", function (e) {
                var target = e.target || e.srcElement;
                if (target && target.classList && target.classList.contains("js-ticket-select")) {
                    updateBulkCloseBar();
                }
            });

            var selectAll = document.getElementById("selectAllTickets");
            if (selectAll) {
                selectAll.addEventListener("change", function () {
                    var all = document.querySelectorAll(".js-ticket-select");
                    var isChecked = selectAll.checked;
                    for (var i = 0; i < all.length; i++) {
                        all[i].checked = isChecked;
                    }
                    updateBulkCloseBar();
                });
            }

            var bulkCloseButton = document.getElementById("bulkCloseButton");
            if (bulkCloseButton) {
                bulkCloseButton.addEventListener("click", function () {
                    var checked = document.querySelectorAll(".js-ticket-select:checked");
                    if (!checked.length) {
                        return;
                    }

                    if (!window.confirm("Are you sure you want to close the selected tickets?")) {
                        return;
                    }

                    var ticketIds = [];
                    for (var i = 0; i < checked.length; i++) {
                        var id = checked[i].getAttribute("data-ticket-id");
                        if (id) {
                            ticketIds.push(id.toString());
                        }
                    }

                    if (!ticketIds.length) {
                        return;
                    }

                    bulkCloseButton.disabled = true;

                    var xhr = new XMLHttpRequest();
                    xhr.open("POST", "@Url.Action("BulkCloseTickets", "Home")", true);
                    xhr.setRequestHeader("Content-Type", "application/x-www-form-urlencoded; charset=UTF-8");

                    xhr.onreadystatechange = function () {
                        if (xhr.readyState === 4) {
                            bulkCloseButton.disabled = false;
                            if (xhr.status >= 200 && xhr.status < 300) {
                                var response = null;
                                try {
                                    response = JSON.parse(xhr.responseText);
                                } catch (e) {
                                    response = null;
                                }

                                if (response && response.success) {
                                    window.location.reload();
                                } else {
                                    var msg = (response && response.message) || "Failed to close selected tickets.";
                                    window.alert(msg);
                                }
                            } else {
                                window.alert("Failed to close selected tickets.");
                            }
                        }
                    };

                    var parts = [];
                    for (var j = 0; j < ticketIds.length; j++) {
                        parts.push("ticketIds=" + encodeURIComponent(ticketIds[j]));
                    }
                    var body = parts.join("&");
                    xhr.send(body);
                });
            }
        })();
    </script>
}
