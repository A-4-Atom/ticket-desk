<div class="modal fade" id="createTicketModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-fullscreen-sm-down modal-lg">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-0 px-4 pt-4">
                <h5 class="modal-title fw-bold">Create New Ticket</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body px-4 pb-4">
                @using (Html.BeginForm("CreateTicket", "Home", FormMethod.Post, new { id = "createTicketForm", enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ticketTypeKey" id="ticketTypeKey" />
                    <input type="hidden" name="category" id="ticketCategory" />
                    <input type="hidden" name="isDraft" id="isDraft" value="false" />

                    <div class="alert alert-light border d-none mb-3" id="requesterInfo">
                        <div class="d-flex justify-content-between small">
                            <div><strong>Requester:</strong> @Session["UserName"]</div>
                            <div><strong>Employee Code:</strong> @Session["EmployeeCode"]</div>
                        </div>
                    </div>
                    <div id="createTicketError" class="alert alert-danger d-none" role="alert"></div>
                    <div id="normalTicketFields">
                        <div class="mb-3">
                            <label class="form-label text-uppercase small fw-bold text-muted">Title</label>
                            <input name="title" id="title" type="text" class="form-control form-control-lg"
                                   placeholder="Brief summary of the issue" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-uppercase small fw-bold text-muted">Category</label>
                            <input name="category" id="categoryInput" type="text" class="form-control form-control-lg"
                                   placeholder="IT Support, HR Support, General Service..." required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-uppercase small fw-bold text-muted">Description</label>
                            <textarea name="description" id="description" class="form-control" rows="4"
                                      placeholder="Detailed explanation..." required></textarea>
                        </div>

                        <div class="form-check mb-3 d-none" id="confidentialityWrapper">
                            <input class="form-check-input" type="checkbox" value="true" id="isConfidential" name="isConfidential">
                            <label class="form-check-label small" for="isConfidential">
                                Mark as confidential (HR will restrict visibility)
                            </label>
                        </div>
                    </div>

                    <div id="adminTicketFields" class="d-none">
                        <div id="newEmployeeFields" class="d-none">
                            <div class="mb-3">
                                <label class="form-label text-uppercase small fw-bold text-muted">New Hire Name</label>
                                <input name="newHireName" type="text" class="form-control form-control-lg" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-uppercase small fw-bold text-muted">Start Date</label>
                                <input name="startDate" type="date" class="form-control form-control-lg" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-uppercase small fw-bold text-muted">Position / Role</label>
                                <input name="position" type="text" class="form-control form-control-lg" />
                            </div>
                        </div>

                        <div id="employeeSeparationFields" class="d-none">
                            <div class="mb-3">
                                <label class="form-label text-uppercase small fw-bold text-muted">Employee Name</label>
                                <input name="employeeName" type="text" class="form-control form-control-lg" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-uppercase small fw-bold text-muted">Last Working Day</label>
                                <input name="lastWorkingDay" type="date" class="form-control form-control-lg" />
                            </div>
                        </div>

                        <div id="assetOrderFields" class="d-none">
                            <div class="mb-3">
                                <label class="form-label text-uppercase small fw-bold text-muted">Item Name</label>
                                <input name="itemName" type="text" class="form-control form-control-lg" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-uppercase small fw-bold text-muted">Quantity</label>
                                <input name="quantity" type="number" min="1" class="form-control form-control-lg" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-uppercase small fw-bold text-muted">Description</label>
                            <textarea name="description" class="form-control" rows="4"></textarea>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-uppercase small fw-bold text-muted">
                            Attachments (<span id="attachmentCount">0</span>/5)
                        </label>

                        <input id="attachments" name="attachments" class="form-control form-control-lg" type="file" multiple />
                        <div class="form-text">
                            You can upload up to 5 files.
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <button type="submit" class="btn btn-outline-secondary" id="saveAsDraftButton">
                            Save as Draft
                        </button>
                        <button type="submit" class="btn btn-primary" id="submitTicketButton">
                            Create Ticket
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        var form = document.getElementById('createTicketForm');
        if (!form) return;

        var filesInput = document.getElementById('attachments');
        var countSpan = document.getElementById('attachmentCount');
        var errorBox = document.getElementById('createTicketError');
        var tokenInput = form.querySelector('input[name="__RequestVerificationToken"]');
        var isDraftInput = document.getElementById('isDraft');

        if (filesInput && countSpan) {
            filesInput.addEventListener('change', function () {
                var files = Array.prototype.slice.call(filesInput.files || []);
                if (files.length > 5) {
                    // Enforce max 5 files client-side and show message in modal
                    if (errorBox) {
                        errorBox.textContent = 'You can upload a maximum of 5 attachments.';
                        errorBox.classList.remove('d-none');
                    }
                    filesInput.value = '';
                    countSpan.textContent = '0';
                } else {
                    countSpan.textContent = files.length.toString();
                    if (errorBox) {
                        errorBox.classList.add('d-none');
                        errorBox.textContent = '';
                    }
                }
            });
        }

        var isDraftMode = false;
        var saveDraftButton = document.getElementById('saveAsDraftButton');
        var submitTicketButton = document.getElementById('submitTicketButton');

        if (saveDraftButton) {
            saveDraftButton.addEventListener('click', function () {
                isDraftMode = true;
            });
        }

        if (submitTicketButton) {
            submitTicketButton.addEventListener('click', function () {
                isDraftMode = false;
            });
        }

        form.addEventListener('submit', function (e) {
            e.preventDefault();

            if (errorBox) {
                errorBox.classList.add('d-none');
                errorBox.textContent = '';
            }

            var titleInput = form.querySelector('input[name="title"]');
            var descriptionInput = form.querySelector('textarea[name="description"]');
            var ticketTypeKeyInput = document.getElementById('ticketTypeKey');
            var categoryHiddenInput = document.getElementById('ticketCategory');
            var categoryVisibleInput = document.getElementById('categoryInput');

            var title = titleInput ? titleInput.value : '';
            var category = '';
            if (categoryVisibleInput && categoryVisibleInput.value) {
                category = categoryVisibleInput.value;
            } else if (categoryHiddenInput && categoryHiddenInput.value) {
                category = categoryHiddenInput.value;
            }
            var description = descriptionInput ? descriptionInput.value : '';

            var formData = new FormData();

            var isDraft = isDraftMode;
            if (isDraftInput) {
                isDraftInput.value = isDraft ? 'true' : 'false';
            }

            // add anti-forgery token to the request
            if (tokenInput) {
                formData.append('__RequestVerificationToken', tokenInput.value);
            }

            formData.append('title', title);
            formData.append('category', category);
            formData.append('description', description);

            formData.append('isDraft', isDraft ? 'true' : 'false');

            if (ticketTypeKeyInput) {
                formData.append('ticketTypeKey', ticketTypeKeyInput.value || 'it-support');
            }

            var isConfidentialCheckbox = document.getElementById('isConfidential');
            if (isConfidentialCheckbox && isConfidentialCheckbox.checked) {
                formData.append('isConfidential', 'true');
            }

            // Attach files
            if (filesInput && filesInput.files) {
                var files = Array.prototype.slice.call(filesInput.files);
                if (files.length > 5) {
                    if (errorBox) {
                        errorBox.textContent = 'You can upload a maximum of 5 attachments.';
                        errorBox.classList.remove('d-none');
                    }
                    return;
                }

                files.forEach(function (file) {
                    formData.append('attachments', file);
                });
            }

            // Post to Controller
            fetch('/Home/CreateTicket', {
                method: 'POST',
                body: formData
            }).then(function (response) {
                if (response.redirected) {
                    window.location.href = response.url;
                } else if (response.ok) {
                    window.location.reload();
                } else {
                    if (errorBox) {
                        errorBox.textContent = 'Ticket creation failed. Please try again.';
                        errorBox.classList.remove('d-none');
                    }
                }
            }).catch(function () {
                if (errorBox) {
                    errorBox.textContent = 'Ticket creation failed. Please try again.';
                    errorBox.classList.remove('d-none');
                }
            });
        });
    })();
</script>
